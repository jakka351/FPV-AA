<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FpvGauges.Pages.SettingsPage"
             Title="Configure Gauges"
             BackgroundColor="{StaticResource FpvDark}">

    <Grid RowDefinitions="*,Auto" Padding="12" RowSpacing="12">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout x:Name="Container" Spacing="14" />
        </ScrollView>

        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8">
            <Button Grid.Column="0" Text="Reset to FPV default" Clicked="OnResetClicked"
                    BackgroundColor="#2A2F3A" TextColor="{StaticResource FpvText}" />
            <Button Grid.Column="1" Text="Save" Clicked="OnSaveClicked" />
        </Grid>
    </Grid>
</ContentPage>
